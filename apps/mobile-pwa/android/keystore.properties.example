# Copy to keystore.properties next to this file, fill in real values, and keep keystore.properties out of git.
#
# Generate a keystore (once):
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Register the upload key in Play Console: Setup → App integrity → Upload key (if using Play App Signing).

storePassword=change-me
keyPassword=change-me
keyAlias=upload
storeFile=upload-keystore.jks
