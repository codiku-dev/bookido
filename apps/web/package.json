{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dotenvx": "dotenvx",
    "dev": "npx turbo run build --filter=@repo/emails && concurrently -n styles,components,check,next --kill-others-on-fail \"npx turbo run dev:styles --filter=@repo/ui\" \"npx turbo run dev:components --filter=@repo/ui\" \"npm run check-env:watch\" \"npm run dev:web\"",
    "check-env:watch": "cd ../.. && npm run check-env:watch",
    "dev:web": "npx dotenvx run -f .env.local.development -- next dev --webpack",
    "build": "npx dotenvx run -f .env.production -- next build --webpack",
    "start": "npx dotenvx run -f .env.production -- next start",
    "start:prod": "npx dotenvx run -f .env.production -- next start",
    "lint": "npx dotenvx run -f .env.production -- next lint --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test:e2e": "PLAYWRIGHT_HTML_OPEN=never playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.0",
    "@playwright/mcp": "^0.0.70",
    "@radix-ui/react-accordion": "^1.2.12",
