    "@repo/typescript-config": "*",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.19",
    "@trpc/react-query": "11.8.1",
    "@types/node": "25.0.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.2",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
